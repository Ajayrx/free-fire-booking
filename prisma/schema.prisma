generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Match {
  id          String    @id @default(uuid())
  date        DateTime
  matchNumber Int
  status      String    @default("OPEN") // OPEN, LOCKED, FULL, COMPLETED
  slots       Slot[]
  bookings    Booking[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Booking {
  id             String   @id @default(uuid())
  playerName     String
  whatsappNumber String
  senderUpiId    String
  status         String   @default("PENDING") // PENDING, APPROVED, REJECTED
  matchId        String
  match          Match    @relation(fields: [matchId], references: [id])
  slots          Slot[]
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Slot {
  id          String   @id @default(uuid())
  slotNumber  Int
  status      String   @default("AVAILABLE") // AVAILABLE, PENDING, BOOKED
  freeFireUid String?
  bookingId   String?
  booking     Booking? @relation(fields: [bookingId], references: [id])
  matchId     String
  match       Match    @relation(fields: [matchId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([matchId, slotNumber])
}
